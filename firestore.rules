rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile, and update their own name, avatar, and unlocked status.
    // They cannot write to their own coins field.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId
                          && request.resource.data.keys().hasAll(['name', 'avatarUrl', 'hasUnlockedTestSeries']) == false; // Prevent updating other fields
      allow create: if request.auth.uid == userId;
    }

    // Questions can only be read by authenticated users. No one can write to them.
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false; // Disallow client-side writes
    }

    // Test Series questions can only be read by authenticated users.
    match /testSeries/{questionId} {
      allow read: if request.auth != null;
      allow write: if false; // Disallow client-side writes
    }
  }
}
